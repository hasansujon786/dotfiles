{
  "twMerge": {
    "prefix": "twMerge",
    "body": [
      "/* yarn add tailwind-merge class-variance-authority clsx */",
      "import { clsx, type ClassValue } from 'clsx'",
      "import { twMerge } from 'tailwind-merge'\n",
      "export function cn(...inputs: ClassValue[]) {",
      "  return twMerge(clsx(inputs))",
      "}"
    ],
    "description": "twMerge"
  },
  "cva": {
    "prefix": "cva",
    "body": [
      "import { cva, type VariantProps } from \"class-variance-authority\";",
      "export const button = cva(",
      "  \"px-4 py-2 font-medium rounded\",",
      "  {",
      "    variants: {",
      "      variant: {",
      "        primary: \"bg-blue-500 text-white\",",
      "        secondary: \"bg-gray-200 text-black\",",
      "      },",
      "      size: {",
      "        sm: \"text-sm\",",
      "        lg: \"text-lg\",",
      "      },",
      "    },",
      "    defaultVariants: {",
      "      variant: \"primary\",",
      "      size: \"sm\",",
      "    },",
      "  }",
      ");"
    ],
    "description": "simple cva usage example"
  },
  "value as union type": {
    "prefix": "typeUnionValue",
    "body": "type ${2:TypeName} = (typeof ${1:object})[keyof typeof ${1:object}]",
    "description": "Create a union type from all values of an object"
  },
  "key as union type": {
    "prefix": "typeUnionKey",
    "body": "type ${2:TypeName} = keyof typeof ${1:object}",
    "description": "Create a union type from all keys of an object"
  },
  "Array Values to Union Type": {
    "prefix": "typeUnionArrayValues",
    "body": "type ${2:TypeName} = (typeof ${1:array})[number];",
    "description": "Create a union type from the values of a readonly array or tuple in TypeScript"
  },
  "typePrettify": {
    "prefix": "typePrettify",
    "body": ["type Prettify<T> = {", "  [K in keyof T]: T[K]", "} & {}"],
    "description": "Flatten and normalize TypeScript types for better editor display"
  },
  "Const array to union type": {
    "prefix": "constarr-union",
    "body": [
      "export const ${1:NAME} = [",
      "  ${2:'VALUE_1'},",
      "  ${3:'VALUE_2'},",
      "] as const",
      "",
      "export type ${4:${1/(.*)/${1:/pascalcase}/}} = (typeof ${1})[number]$0"
    ],
    "description": "Create const array and infer union type"
  },
  "Const object values to union type": {
    "prefix": "constobj-union",
    "body": [
      "export const ${1:NAME} = {",
      "  ${2:key1}: ${3:'value1'},",
      "  ${4:key2}: ${5:'value2'},",
      "} as const",
      "",
      "export type ${6:${1/(.*)/${1:/pascalcase}/}} = (typeof ${1})[keyof typeof ${1}]$0"
    ],
    "description": "Create const object and infer union of values"
  }
}
